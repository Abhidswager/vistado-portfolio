# ───────────────────────────────────────────────
# Formspree contact-form endpoint
# 1. Create a form at https://formspree.io
# 2. Copy your endpoint (looks like https://formspree.io/f/abcdwxyz)
# 3. Paste it below, then rename this file to ".env.local"
# ───────────────────────────────────────────────
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Public site URL (used for SEO / sitemap / Open Graph)
NEXT_PUBLIC_SITE_URL=https://vistado.com
